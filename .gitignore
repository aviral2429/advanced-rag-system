# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc
.Python

# ── Virtual environments ──────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment variables (API keys — NEVER commit these) ─────────
.env
# Keep the example file for reference
!.env.example

# ── Model & embedding caches (large binary files) ────────────────
.cache/
*.joblib
*.index

# ── Streamlit ────────────────────────────────────────────────────
.streamlit/

# ── Evaluation logs (auto-generated runtime data) ─────────────────
eval_log.jsonl

# ── OS / editor junk ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Build / dist ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Pytest / coverage ─────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Jupyter notebooks checkpoints ─────────────────────────────────
.ipynb_checkpoints/

# ── Temp / data uploads (PDFs uploaded at runtime) ────────────────
data/
tmp/

# ══════════════════════════════════════════════════════════════════
# Advanced RAG System — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────────
# Options: "together" | "openai" | "anthropic"
LLM_PROVIDER=together

# ── API Keys (fill in the one(s) you use) ─────────────────────────
TOGETHER_API_KEY=your_together_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Model Names (defaults shown) ──────────────────────────────────
TOGETHER_MODEL=mistralai/Mistral-7B-Instruct-v0.2
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Embedding Model ───────────────────────────────────────────────
# BAAI/bge-large-en-v1.5 — ~1.3 GB download, MTEB top-tier
# Use BAAI/bge-small-en-v1.5 for faster CPU inference (~130 MB)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_BATCH_SIZE=32

# ── Reranker ──────────────────────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
USE_RERANKER=true

# ── Chunking ──────────────────────────────────────────────────────
CHUNK_SIZE=1024
CHUNK_OVERLAP=150
# "semantic" (preferred) or "recursive" (faster baseline)
CHUNKING_STRATEGY=semantic
SEMANTIC_BREAKPOINT_PERCENTILE=85

# ── Retrieval ─────────────────────────────────────────────────────
TOP_K=5
RETRIEVAL_CANDIDATES=50
RRF_K=60
CONFIDENCE_THRESHOLD=0.3

# ── LLM Generation ────────────────────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── Hallucination Detection ───────────────────────────────────────
FAITHFULNESS_WARNING_THRESHOLD=0.4

# ── Caching ───────────────────────────────────────────────────────
EMBED_CACHE_DIR=.cache/embeddings
INDEX_CACHE_DIR=.cache/index

# ── Evaluation Logging ────────────────────────────────────────────
EVAL_LOG_PATH=eval_log.jsonl
